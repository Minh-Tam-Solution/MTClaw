{
  "agents": {
    "defaults": {
      "workspace": "/home/nqh/shared/MTClaw"
    },
    "list": {
      "default": {
        "displayName": "Assistant",
        "provider": "bflow-ai-platform",
        "model": "qwen3:14b"
      },
      "pm": {
        "displayName": "PM",
        "provider": "bflow-ai-platform",
        "model": "qwen3:14b"
      }
    }
  },
  "bridge": {
    "enabled": true,
    "hook_port": 18792,
    "admission": {
