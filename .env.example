# MTClaw Environment Configuration
# Copy to .env and fill in values. NEVER commit .env

# PostgreSQL
GOCLAW_POSTGRES_DSN=postgres://mtclaw:changeme@localhost:5432/mtclaw?sslmode=disable

# Encryption (generate: openssl rand -hex 32)
GOCLAW_ENCRYPTION_KEY=

# Bflow AI-Platform (single source of AI infra truth)
# Auth: X-API-Key + X-Tenant-ID headers (not standard Bearer)
GOCLAW_BFLOW_API_KEY=
GOCLAW_BFLOW_BASE_URL=http://ai-platform:8120/api/v1
BFLOW_TENANT_ID=mts

# Default provider + model
GOCLAW_PROVIDER=bflow-ai-platform
GOCLAW_MODEL=qwen3:14b

# Telegram Bot (Phase 1 channel)
GOCLAW_TELEGRAM_TOKEN=
GOCLAW_TELEGRAM_POLLING=true

# Server
GOCLAW_PORT=8080
GOCLAW_LOG_LEVEL=info
GOCLAW_LOG_FORMAT=json

# Observability (OTEL)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mtclaw

# Tenant Cost Guardrails
TENANT_MONTHLY_TOKEN_LIMIT=1000000
TENANT_DAILY_REQUEST_LIMIT=5000
