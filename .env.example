# MTClaw Environment Configuration
# Copy to .env and fill in values. NEVER commit .env

# PostgreSQL
MTCLAW_POSTGRES_DSN=postgres://mtclaw:changeme@localhost:5432/mtclaw?sslmode=disable

# Encryption (generate: openssl rand -hex 32)
MTCLAW_ENCRYPTION_KEY=

# Bflow AI-Platform (single source of AI infra truth)
# Auth: X-API-Key + X-Tenant-ID headers (not standard Bearer)
MTCLAW_BFLOW_API_KEY=
MTCLAW_BFLOW_BASE_URL=http://ai-platform:8120/api/v1
BFLOW_TENANT_ID=mts

# Default provider + model
MTCLAW_PROVIDER=bflow-ai-platform
MTCLAW_MODEL=qwen3:14b

# Telegram Bot (Phase 1 channel)
MTCLAW_TELEGRAM_TOKEN=
MTCLAW_TELEGRAM_POLLING=true

# Server
MTCLAW_PORT=8080
MTCLAW_LOG_LEVEL=info
MTCLAW_LOG_FORMAT=json

# Observability (OTEL)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mtclaw

# Tenant Cost Guardrails
TENANT_MONTHLY_TOKEN_LIMIT=1000000
TENANT_DAILY_REQUEST_LIMIT=5000

# GitHub PR Gate ENFORCE (Sprint 8)
# PAT with repo scope (or public_repo for public repos only)
GITHUB_APP_TOKEN=
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# MS Teams Bot Framework (Sprint 10 — ADR-007)
# Register a Bot Channel at https://dev.botframework.com/ (requires Azure AD app)
# PRODUCTION: MSTEAMS_TENANT_ID must be your org's specific Azure tenant ID — NEVER "common"
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=
MSTEAMS_TENANT_ID=

# Claude CLI Fallback Provider (Sprint 24-25 — ADR-014)
# Uses Claude Max $200 subscription (OAuth) — NOT API key billing.
# Requires `claude` CLI v2.1.71+ installed and logged in via `claude login`.
# ENABLE_CLAUDE_CLI: Docker build arg — installs nodejs+npm+@anthropic-ai/claude-code in image.
ENABLE_CLAUDE_CLI=false
MTCLAW_CLAUDE_ENABLED=false
MTCLAW_CLAUDE_PATH=/usr/local/bin/claude
MTCLAW_CLAUDE_MODEL=sonnet
MTCLAW_CLAUDE_TIMEOUT=120

# Provider fallback chain (comma-separated, ordered by preference)
# When primary provider fails with retryable error, try next in chain.
MTCLAW_PROVIDER_CHAIN=bflow-ai-platform,claude-cli
