# MTClaw Environment Configuration
# Copy to .env and fill in values. NEVER commit .env

# PostgreSQL
GOCLAW_POSTGRES_DSN=postgres://mtclaw:changeme@localhost:5432/mtclaw?sslmode=disable

# Encryption (generate: openssl rand -hex 32)
GOCLAW_ENCRYPTION_KEY=

# Bflow AI-Platform (single source of AI infra truth)
BFLOW_AI_API_KEY=
BFLOW_TENANT_ID=mts

# Telegram Bot (Phase 1 channel)
TELEGRAM_BOT_TOKEN=

# Server
GOCLAW_PORT=8080
GOCLAW_LOG_LEVEL=info
GOCLAW_LOG_FORMAT=json

# Observability (OTEL)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mtclaw

# Tenant Cost Guardrails
TENANT_MONTHLY_TOKEN_LIMIT=1000000
TENANT_DAILY_REQUEST_LIMIT=5000
